// Yardex data model
// Multi-tenant: every wholesaler is a tenant. Global catalog is shared,
// prices are tenant-overridable per product.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN // Yardex staff (you)
  DEALER_OWNER // primary login for a wholesaler
  DEALER_STAFF // sub-user under a wholesaler
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
}

model Dealer {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  contactEmail String
  contactPhone String?
  logoUrl      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users       User[]
  priceList   PriceOverride[]
  quotes      Quote[]
  template    QuoteTemplate?
  projects    Project[]
  installers  Installer[]
  invoices    Invoice[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(DEALER_STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dealerId String?
  dealer   Dealer? @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  quotesCreated    Quote[]           @relation("CreatedBy")
  projectDocuments ProjectDocument[] @relation("ProjectDocumentUploader")

  @@index([dealerId])
}

model Product {
  id            String   @id @default(uuid())
  sku           String   @unique
  name          String
  category      String // e.g. "PANEL", "POST", "GATE", "ACCESSORY"
  description   String?
  unit          String // "pcs", "linear_ft", "set"
  basePrice     Decimal  @db.Decimal(12, 2)
  heightOptions String[] // e.g. ["4ft","5ft","6ft"]
  colorOptions  String[] // e.g. ["Black","White","Bronze"]
  imageUrl      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  priceOverrides    PriceOverride[]
  lineItems         QuoteLineItem[]
  designProducts    DesignProduct[]
  projectSelections ProjectFenceSelection[]
}

model PriceOverride {
  id           String     @id @default(uuid())
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  dealerId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  price        Decimal    @db.Decimal(12, 2)

  @@unique([dealerId, productId])
}

model Design {
  id          String   @id @default(uuid())
  name        String
  style       String // e.g. "Privacy", "Picket", "Wrought Iron"
  description String?
  // Path (relative to DATA_DIR) of the overlay texture / 2D asset.
  overlayUrl  String
  // JSON metadata for the renderer: scale, anchor, transparency, etc.
  config      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  designProducts    DesignProduct[]
  quotes            Quote[]
  projectSelections ProjectFenceSelection[]
}

model DesignProduct {
  id        String  @id @default(uuid())
  design    Design  @relation(fields: [designId], references: [id], onDelete: Cascade)
  designId  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  // meters of fence covered by 1 unit of this product (e.g. 1 panel = 2.4m)
  coverage  Decimal @db.Decimal(8, 2)

  @@unique([designId, productId])
}

model QuoteTemplate {
  id           String     @id @default(uuid())
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  dealerId String     @unique
  headerHtml   String?    @db.Text
  footerHtml   String?    @db.Text
  termsHtml    String?    @db.Text
  accentColor  String? // hex
  updatedAt    DateTime   @updatedAt
}

model Quote {
  id           String     @id @default(uuid())
  reference    String     @unique // human-friendly e.g. FVP-2026-0001
  dealer   Dealer @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  dealerId String

  customerName   String
  customerEmail  String
  customerPhone  String?
  projectAddress String?
  notes          String? @db.Text

  status               QuoteStatus @default(DRAFT)
  validUntil           DateTime?
  approvedAt           DateTime?
  approvedSignatureUrl String?

  // Floor plan: original upload + measured fence layout
  floorPlanUrl     String?
  floorPlanWidthM  Float? // real-world width of the plan in meters
  floorPlanHeightM Float? // real-world height of the plan in meters
  fenceSegments    Json? // [{x1,y1,x2,y2,lengthM,productId,designId}]

  selectedDesignId String?
  selectedDesign   Design? @relation(fields: [selectedDesignId], references: [id])

  renderUrl   String? // composited preview image
  pdfUrl      String? // generated quotation PDF
  threeJsCode String? @db.Text // LLM-generated three.js source for the 3D preview

  // One AI-generated photorealistic render per quote line item,
  // in the same order as `lineItems`. The list and the items
  // list can be out of sync (a partial render run) - the UI
  // pairs them by index. The 2D top-down composite continues
  // to live in `renderUrl`; the AI renders are the customer-
  // facing photorealistic images generated by /ai/render-image.
  //
  // String[] is supported on PostgreSQL (which is what the
  // production yardex_db runs); NOT supported on SQLite.
  aiImageUrls        String[] @default([])
  // A single "scene overview" image that shows the whole
  // property, as opposed to per-line-item close-ups. Set
  // explicitly via /ai/render-image with `overview: true`.
  aiOverviewImageUrl String?

  subtotal  Decimal @default(0) @db.Decimal(12, 2)
  taxRate   Decimal @default(0) @db.Decimal(5, 2)
  taxAmount Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @default(0) @db.Decimal(12, 2)

  createdById String?
  createdBy   User?    @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lineItems    QuoteLineItem[]
  projectId    String?
  project      Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  installation Installation?
  invoices     Invoice[]

  @@index([dealerId])
  @@index([status])
}

model QuoteLineItem {
  id        String  @id @default(uuid())
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId   String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId String

  description String
  quantity    Decimal @db.Decimal(12, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)

  // Optional height/color selected for this line
  heightOption String?
  colorOption  String?

  @@index([quoteId])
}

enum ProjectType {
  RESIDENTIAL
  COMMERCIAL
}

enum InstallScope {
  FULL
  HALF
  PARTIAL
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  QUOTED
  APPROVED
  INSTALLED
  CANCELLED
}

enum ProjectDocumentKind {
  SITE_PHOTO
  FLOOR_PLAN
  PROPERTY_DEED
  REFERENCE_IMAGE
  OTHER
}

enum ProjectVisualizationKind {
  AI_IMAGE
  AI_3D_SNAPSHOT
  TOPDOWN_COMPOSITE
}

model Project {
  id                String        @id @default(cuid())
  dealer        Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  dealerId      String
  customerName      String
  customerEmail     String?
  customerPhone     String?
  customerAddress   String?
  projectType       ProjectType   @default(RESIDENTIAL)
  installScope      InstallScope
  status            ProjectStatus @default(DRAFT)
  totalLinearMeters Float?
  totalAreaSqM      Float?
  notes             String?
  submittedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  documents      ProjectDocument[]
  selections     ProjectFenceSelection[]
  measurements   ProjectMeasurement[]
  visualizations ProjectVisualization[]
  quotes         Quote[]

  @@index([dealerId])
  @@index([status])
  @@index([installScope])
  @@index([projectType])
}

model ProjectDocument {
  id               String              @id @default(cuid())
  project          Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  kind             ProjectDocumentKind
  originalFilename String
  mimeType         String
  sizeBytes        Int
  widthPx          Int?
  heightPx         Int?
  data             Bytes
  uploadedBy       User?               @relation("ProjectDocumentUploader", fields: [uploadedById], references: [id])
  uploadedById     String?
  uploadedAt       DateTime            @default(now())
  caption          String?

  @@index([projectId, kind])
}

model ProjectFenceSelection {
  id           String  @id @default(cuid())
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  product      Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  productId    String
  design       Design? @relation(fields: [designId], references: [id], onDelete: SetNull)
  designId     String?
  linearMeters Float
  heightFt     Float
  panelCount   Int?
  gateCount    Int?
  notes        String?
  sortOrder    Int     @default(0)

  @@index([projectId])
}

model ProjectMeasurement {
  id        String  @id @default(cuid())
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  label     String
  lengthM   Float
  heightFt  Float
  widthM    Float?
  slopeDeg  Float?
  notes     String?

  @@index([projectId])
}

model ProjectVisualization {
  id          String                   @id @default(cuid())
  project     Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  kind        ProjectVisualizationKind
  mimeType    String
  data        Bytes
  prompt      String?
  modelUsed   String?
  widthPx     Int?
  heightPx    Int?
  // The raw three.js source for AI_3D_SNAPSHOT entries. Stored
  // so the dealer can re-open the exact scene that produced
  // this snapshot (drag/zoom from a different angle, etc.) -
  // otherwise only the static image survives a refresh. NULL
  // for AI_IMAGE and TOPDOWN_COMPOSITE entries.
  sourceCode  String?                  @db.Text
  generatedAt DateTime                 @default(now())

  @@index([projectId, kind])
}

// ---------------------------------------------------------------------------
// Installation traceability
// ---------------------------------------------------------------------------
// An Installation is the post-quote, on-site execution record. It tracks the
// physical work the installer does, the photo evidence they capture, and the
// milestone updates visible to the wholesaler and end customer. Each
// Installation has exactly one Quote (1:1, quoteId @unique) and lives a
// linear lifecycle SCHEDULED -> MATERIALS_ORDERED -> IN_PROGRESS -> COMPLETED
// -> INSPECTED. CANCELLED is a side branch that exits the lifecycle.

enum InstallationStatus {
  SCHEDULED // Quote approved, awaiting kickoff
  MATERIALS_ORDERED
  IN_PROGRESS
  COMPLETED // Installer marked done; awaiting customer inspection
  INSPECTED // Customer signed off
  CANCELLED
}

enum InstallationEventType {
  SCHEDULED
  KICKOFF
  MATERIALS_ORDERED
  MATERIALS_RECEIVED
  POSTS_SET
  PANELS_HUNG
  GATE_INSTALLED
  PHOTO_UPLOADED
  NOTE_ADDED
  IN_PROGRESS
  COMPLETED
  INSPECTED
  CUSTOMER_APPROVED
  CANCELLED
  PUBLIC_LINK_ISSUIED
}

model Installation {
  id             String             @id @default(cuid())
  quote          Quote              @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteId        String             @unique // one installation per quote
  status         InstallationStatus @default(SCHEDULED)
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  installerName  String? // free-form (snapshot taken at issue time)
  installerPhone String?
  installerEmail String?
  installer      Installer? @relation(fields: [installerId], references: [id], onDelete: SetNull)
  installerId    String?
  startedAt      DateTime?
  completedAt    DateTime?
  inspectedAt    DateTime?
  cancelledAt    DateTime?

  events        InstallationEvent[]
  photos        InstallationPhoto[]
  customerLinks PublicCustomerLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledStart])
  @@index([installerId])
}

model InstallationEvent {
  id             String                @id @default(cuid())
  installation   Installation          @relation(fields: [installationId], references: [id], onDelete: Cascade)
  installationId String
  type           InstallationEventType
  actorKind      String // "WHOLESALER_OWNER" | "WHOLESALER_STAFF" | "INSTALLER" | "CUSTOMER" | "SYSTEM"
  actorLabel     String? // human-readable label e.g. "Acme Fence Co (installer)"
  note           String?               @db.Text
  occurredAt     DateTime              @default(now())
  metadata       Json? // free-form (gateCount changed, materials list, etc.)

  @@index([installationId, occurredAt])
}

model InstallationPhoto {
  id               String       @id @default(cuid())
  installation     Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  installationId   String
  kind             String // "BEFORE" | "DURING" | "AFTER" | "ISSUE" - keep as String for future flexibility
  caption          String?
  originalFilename String
  mimeType         String
  sizeBytes        Int
  widthPx          Int?
  heightPx         Int?
  data             Bytes
  uploadedByKind   String // "INSTALLER" | "WHOLESALER" | "CUSTOMER"
  uploadedByLabel  String?
  takenAt          DateTime? // when photo was actually taken (vs upload time)
  uploadedAt       DateTime     @default(now())

  @@index([installationId, kind])
}

model PublicCustomerLink {
  id             String       @id @default(cuid())
  installation   Installation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  installationId String
  token          String       @unique // random 32-byte hex
  purpose        String // "STATUS_UPDATE" | "COMPLETION_REVIEW" | "ALL"
  revokedAt      DateTime?
  lastViewedAt   DateTime?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([installationId])
}

// ---------------------------------------------------------------------------
// Installer directory
// ---------------------------------------------------------------------------
// An Installer is a contractor a dealer can assign to an
// installation. The free-form `installerName` / `installerPhone` /
// `installerEmail` on Installation are kept as a denormalised
// snapshot (so the audit trail and public views stay stable when
// the installer is later renamed or deleted); this model is the
// source of truth for *who* the installer currently is.

enum InstallerStatus {
  ACTIVE
  INACTIVE
}

model Installer {
  id            String           @id @default(cuid())
  dealer        Dealer           @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  dealerId      String
  name          String
  phone         String? // per-installer mobile — entered by the dealer, NOT seeded
  email         String? // per-installer email — entered by the dealer, NOT seeded
  companyName   String?
  status        InstallerStatus  @default(ACTIVE)
  notes         String?
  installations Installation[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([dealerId])
  @@index([dealerId, status])
}

// ---------------------------------------------------------------------------
// Invoicing
// ---------------------------------------------------------------------------
// An Invoice is a financial artefact derived from an APPROVED quote.
// Status moves forward only: DRAFT → SENT → (PAID | VOID).
// DRAFT invoices can be deleted; everything else is part of the
// audit trail.

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

model Invoice {
  id          String              @id @default(cuid())
  dealer      Dealer              @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  dealerId    String
  quote       Quote               @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  quoteId     String
  number      String              @unique // e.g. "INV-2026-0001"
  status      InvoiceStatus       @default(DRAFT)
  issuedAt    DateTime?
  dueAt       DateTime?
  paidAt      DateTime?
  subtotal    Decimal             @db.Decimal(12, 2)
  tax         Decimal             @default(0) @db.Decimal(12, 2)
  total       Decimal             @db.Decimal(12, 2)
  notes       String?
  lineItems   InvoiceLineItem[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([dealerId])
  @@index([quoteId])
  @@index([dealerId, status])
}

model InvoiceLineItem {
  id          String   @id @default(cuid())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  position    Int

  @@index([invoiceId])
}
