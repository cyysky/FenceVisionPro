# --- Database ---
DATABASE_URL=postgresql://fence:fence@db:5432/fencevisionpro

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# --- Storage ---
DATA_DIR=/app/data
PORT=3000

# --- AI / image generation ---
# External OpenAI-compatible service used for AI-powered fence
# visualisations. The actual API key and base URL live in .env
# (gitignored) - this file is the safe template.
AI_ENABLED=true
AI_BASE_URL=
AI_API_KEY=
AI_IMAGE_MODEL=z-image-turbo
AI_CODE_MODEL=mimo-v25-pro
AI_IMAGE_SIZE=1024x1024
AI_IMAGE_STEPS=9
