# Copy to .env and fill in real values. .env is gitignored.
# This file is committed so contributors know which keys to set.

# --- Database ---
DATABASE_URL=postgresql://fence:fence@localhost:5432/fencevisionpro

# --- Auth ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# --- AI / image generation (server-side only) ---
# OpenAI-compatible endpoint for the external image model.
AI_ENABLED=true
AI_BASE_URL=
AI_API_KEY=
AI_IMAGE_MODEL=z-image-turbo
AI_CODE_MODEL=mimo-v25-pro
AI_IMAGE_SIZE=1024x1024
AI_VISION_MODEL=qwen3.5-397b
AI_IMAGE_STEPS=9
